# Firebase web-app config (Phase 2 cloud login).
# Copy this file to ".env.local" and paste in the values from your Firebase
# project: Console → Project settings → General → "Your apps" → Web app → SDK setup.
# .env.local is gitignored, so these never get committed.
#
# Until these are filled in, the app runs in local-only mode (no login).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
